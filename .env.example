# Copy to .env.local (for app) and .env (for worker) and fill in values.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com)
# -----------------------------------------------------------------------------
# Public anon key is safe to expose to the browser (RLS protects data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key bypasses RLS. Used ONLY by the worker and server-side admin
# operations. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Redis (for BullMQ on Railway)
# -----------------------------------------------------------------------------
REDIS_URL=redis://default:password@host:6379

# -----------------------------------------------------------------------------
# Anthropic Claude (primary LLM provider)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model identifiers (can be overridden per module)
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5

# -----------------------------------------------------------------------------
# OpenAI (transcription via Whisper, embeddings fallback)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Kill switch: when true, NO external side-effects happen
# (no publishing, no AI calls, no transcription). Safe for development.
DRY_RUN=false

# Monthly AI budget in NOK øre (e.g. 50000 = 500 kr)
BUDGET_MONTHLY_CENTS=50000
